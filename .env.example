# ============================================================
#  OpenClawFactory — Secrets & Configuration
#  Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ------ AI BACKENDS (at least one required) ------
ANTHROPIC_API_KEY=your_claude_key_here
OPENAI_API_KEY=your_openai_key_here          # optional

# ------ AGENT PERSONAS ------
# These names/roles appear in the dashboard and logs
AGENT_1_NAME=Henry
AGENT_1_ROLE=Researcher
AGENT_1_MODEL=claude-sonnet-4-6

AGENT_2_NAME=Charlie
AGENT_2_ROLE=Developer
AGENT_2_MODEL=claude-sonnet-4-6

AGENT_3_NAME=Sarah
AGENT_3_ROLE=Analyst
AGENT_3_MODEL=claude-sonnet-4-6

AGENT_4_NAME=Max
AGENT_4_ROLE=QA Engineer
AGENT_4_MODEL=claude-sonnet-4-6

# ------ TELEGRAM BOT (optional) ------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------ DASHBOARD SECURITY ------
# Set a strong password — anyone with your IP can reach port 3000
DASHBOARD_PASSWORD=changeme

# ------ BACKEND ------
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# ------ FRONTEND ------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
